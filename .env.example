# ==============================================================================
# CO-DRIVE APPLICATION ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to `.env` or `.env.local` for local execution.
# Make sure to keep your real production values secure and never commit them.

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (PostgreSQL)
# ------------------------------------------------------------------------------
# PostgreSQL database connection URL.
# - Local PostgreSQL: "postgresql://<username>:<password>@localhost:5432/<db_name>?schema=public"
# - Production PostgreSQL (e.g. Supabase, Neon, AWS RDS, GCP Cloud SQL)
# - How to Get: Create a PostgreSQL database on Neon.tech, Supabase.com, or run one locally via Docker.
DATABASE_URL="postgresql://<username>:<password>@localhost:5432/vehicle_tracker?schema=public"
POSTGRES_PRISMA_URL="postgresql://<username>:<password>@localhost:5432/vehicle_tracker?schema=public"

# ------------------------------------------------------------------------------
# 2. BETTER AUTH CONFIGURATION
# ------------------------------------------------------------------------------
# BETTER_AUTH_SECRET: A secure cryptographic secret key used for signing session cookies and tokens.
# - How to Get: Run `openssl rand -hex 32` or `bun x better-auth secret` in your terminal to generate a 32-character hex key.
# - Production: Generate a completely new unique random key.
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-chars-long"

# BETTER_AUTH_URL: The primary base canonical URL of your Better Auth server backend.
# - Local Development: "http://localhost:3000"
# - Production: "https://your-production-domain.com"
BETTER_AUTH_URL="http://localhost:3000"

# NEXT_PUBLIC_APP_URL: The public-facing client-side URL of your Next.js application.
# - Required for client-side Auth redirects and CORS check safety.
# - Local Development: "http://localhost:3000"
# - Production: "https://your-production-domain.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 3. GOOGLE OAUTH SOCIAL INTEGRATION
# ------------------------------------------------------------------------------
# Credentials to enable secure login via Google Account OAuth.
# - How to Get:
#   1. Go to Google Cloud Console (https://console.cloud.google.com/).
#   2. Create a new project or select an existing one.
#   3. Go to "APIs & Services" > "Credentials".
#   4. Click "+ Create Credentials" > "OAuth client ID".
#   5. Choose "Web application" as the application type.
#   6. Add Authorized Redirect URIs:
#      - Local: "http://localhost:3000/api/auth/callback/google"
#      - Production: "https://your-production-domain.com/api/auth/callback/google"
#   7. Copy the client ID and client secret key into the variables below.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret-key"

# ------------------------------------------------------------------------------
# 4. PUSH NOTIFICATIONS CONFIGURATION (Web Push & VAPID)
# ------------------------------------------------------------------------------
# VAPID (Voluntary Application Server Identification) keys for enabling Web Push notifications.
# - How to Get: Generate a VAPID keypair in your terminal using web-push CLI:
#   1. Run `npx web-push generate-vapid-keys`
#   2. Copy the resulting Public Key into NEXT_PUBLIC_VAPID_PUBLIC_KEY
#   3. If a backend delivery script is added later, copy the private key to the server configuration.
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-generated-vapid-public-key"

# ------------------------------------------------------------------------------
# 5. SECURE DAILY EXPIRY CRON-SCHEDULER CONFIGURATION
# ------------------------------------------------------------------------------
# CRON_SECRET: Secret token to authorize the secure automated check-expiry cron endpoint.
# - Endpoint: `/api/notifications/check-expiry` (accessible only with "Authorization: Bearer <CRON_SECRET>")
# - How to Get: Generate a random secure string (e.g. `openssl rand -hex 24` or any UUID key).
# - Production: Put this secret inside your cron orchestrator (e.g. Vercel Cron, GitHub Actions, Cron-job.org).
CRON_SECRET="your-production-cron-secret-token"

# ------------------------------------------------------------------------------
# 6. DEVELOPMENT DIRECT LOGIN BYPASS (DEVELOPER CONVENIENCE ONLY)
# ------------------------------------------------------------------------------
# Enable or disable a mock developer direct login button to bypass Google Login locally.
# - Keep both values "false" by default.
# - For local development only, set both values to "true" if you need the bypass.
# - MUST be configured as "false" in production for maximum security!
NEXT_PUBLIC_DEV_LOGIN_ENABLED="false"
DEV_LOGIN_ENABLED="false"
DEV_LOGIN_EMAIL="dev@codrive.io"
DEV_LOGIN_NAME="CoDrive Developer"
